cs.comfy.org/tutorials/flux/flux-1-kontext-dev) and [blf.ai](https://bfl.ai/models/flux-kontext)\n\nLearn how to prompt for Flux Kontext [HERE](https://docs.comfy.org/tutorials/flux/flux-1-kontext-dev#flux-kontext-prompt-techniques)\n\nLearn more about Nunchaku [HERE](https://github.com/mit-han-lab/ComfyUI-nunchaku)\n"],"color":"#432","bgcolor":"#653"},{"id":219,"type":"ImageCompositeMasked","pos":[385.4865856960839,874.613620755061],"size":[270,188],"flags":{},"order":7,"mode":0,"inputs":[{"localized_name":"destination","name":"destination","type":"IMAGE","link":293},{"localized_name":"source","name":"source","type":"IMAGE","link":288},{"localized_name":"mask","name":"mask","shape":7,"type":"MASK","link":289},{"localized_name":"x","name":"x","type":"INT","widget":{"name":"x"},"link":null},{"localized_name":"y","name":"y","type":"INT","widget":{"name":"y"},"link":null},{"localized_name":"resize_source","name":"resize_source","type":"BOOLEAN","widget":{"name":"resize_source"},"link":null}],"outputs":[{"localized_name":"IMAGE","name":"IMAGE","type":"IMAGE","links":[294,298]}],"properties":{"cnr_id":"comfy-core","ver":"0.21.1","Node name for S&R":"ImageCompositeMasked"},"widgets_values":[900,2400,false]},{"id":224,"type":"RMBG","pos":[-563.3812738634281,1336.3016629412732],"size":[340,403.3125],"flags":{},"order":3,"mode":0,"inputs":[{"localized_name":"Image","name":"image","type":"IMAGE","link":266},{"localized_name":"Model","name":"model","type":"COMBO","widget":{"name":"model"},"link":null},{"localized_name":"Sensitivity","name":"sensitivity","shape":7,"type":"FLOAT","widget":{"name":"sensitivity"},"link":null},{"localized_name":"Processing Resolution","name":"process_res","shape":7,"type":"INT","widget":{"name":"process_res"},"link":null},{"localized_name":"Mask Blur","name":"mask_blur","shape":7,"type":"INT","widget":{"name":"mask_blur"},"link":null},{"localized_name":"Mask Offset","name":"mask_offset","shape":7,"type":"INT","widget":{"name":"mask_offset"},"link":